# Backend Production Environment Variables
# Set these in Vercel Dashboard -> Settings -> Environment Variables

# Security (REQUIRED - Generate a secure random string)
SECRET_KEY=your-super-secret-key-change-this-in-production

# Database (For Vercel, consider using a cloud database like Neon, PlanetScale, or Supabase)
# DATABASE_URL=postgresql://user:password@host:port/database
DATABASE_URL=sqlite:///./store.db

# Admin User Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-secure-password

# CORS - Add your frontend Vercel URL here
# Example: ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000
ALLOWED_ORIGINS=https://your-frontend-url.vercel.app,http://localhost:3000

# File Upload Directory (Vercel uses /tmp - this is ephemeral storage)
UPLOAD_DIR=/tmp/uploads

# App Settings
DEBUG=false
